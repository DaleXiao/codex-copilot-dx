{
  "name": "codex-copilot-dx",
  "version": "0.4.34",
  "description": "Use Codex Desktop, Claude Code, and Claude App with GitHub Copilot",
  "author": "Dale Xiao",
  "type": "module",
  "bin": {
    "codex-copilot-dx": "bin/cli.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/benchmark.mjs",
    "README.md"
  ],
  "keywords": [
    "codex",
    "copilot",
    "github",
    "claude",
    "claude-app",
    "claude-code",
    "claude-desktop",
    "anthropic",
    "openai",
    "proxy",
    "responses-api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dalexiao/codex-copilot-dx.git"
  },
  "homepage": "https://github.com/dalexiao/codex-copilot-dx#readme",
  "bugs": {
    "url": "https://github.com/dalexiao/codex-copilot-dx/issues"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "test": "node --test",
    "test:smoke": "node scripts/offline-smoke.mjs",
    "test:e2e": "bash test/e2e.sh",
    "bench": "node scripts/benchmark.mjs",
    "bench:payload": "node scripts/benchmark.mjs --large-payload",
    "pack:check": "npm pack --dry-run --json",
    "verify": "npm test && npm run test:smoke && npm run pack:check",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0",
    "sharp": "^0.34.5"
  }
}
